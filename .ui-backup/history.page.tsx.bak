import {
  getAllTimeStats,
  getDailyStats,
  getPlaysByDay,
  searchHistory,
} from "@/lib/db";
import { tzOffsetMinutes } from "@/lib/tz";
import { HistoryClient } from "@/components/history-client";

// Reads the DB fresh on each request (also so the tz cookie is honoured).
export const dynamic = "force-dynamic";

export default async function HistoryPage({
  searchParams,
}: {
  // Find's "last played" rows deep-link here: ?day=YYYY-MM-DD&track=<id> opens that day and
  // scrolls to that song.
  searchParams: Promise<{ day?: string; track?: string }>;
}) {
  const tz = await tzOffsetMinutes();
  const { day, track } = await searchParams;
  const [daily, allTime, initialResults] = await Promise.all([
    getDailyStats(tz),
    getAllTimeStats(),
    // Pre-rendered first page of the search list (only shown while searching).
    searchHistory(""),
  ]);
  // Open the deep-linked day if given (even one older than the day strip's window), else
  // default to the most recent day with plays ("today" in practice).
  const focusDay = day ?? null;
  const focusTrackId = track ?? null;
  const initialDay = focusDay ?? daily[0]?.day ?? null;
  const initialDayTracks = initialDay ? await getPlaysByDay(initialDay, tz) : [];

  return (
    <div className="space-y-8">
      {/* The nav already says "History" — a single bigger heading, no subtitle. */}
      <h1 className="text-4xl font-bold tracking-tight">See stuff</h1>
      <HistoryClient
        initialDaily={daily}
        initialDay={initialDay}
        initialDayTracks={initialDayTracks}
        allTime={allTime}
        initialResults={initialResults}
        focusTrackId={focusTrackId}
      />
    </div>
  );
}
