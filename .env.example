# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Spotify app credentials (https://developer.spotify.com/dashboard)
# Add redirect URI: http://127.0.0.1:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Base URL Auth.js uses to build callback URLs. Pin it locally to 127.0.0.1 so the
# redirect_uri matches your registered URI (Spotify rejects "localhost").
AUTH_URL=http://127.0.0.1:3000
# In production set it to your deployed origin, e.g. https://your-domain.com

# Turso (libSQL) — the listen-history + token store. Leave BOTH blank locally to
# fall back to a SQLite file at data/listens.db; set them in prod (and locally if
# you want dev to use Turso too). Get them from: turso db show <name> --url
# and: turso db tokens create <name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Shared secret for the daily Vercel Cron sync (/api/cron/sync). Generate with
# openssl rand -base64 32. Vercel sends it as `Authorization: Bearer <secret>`.
CRON_SECRET=
