# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Spotify app credentials (https://developer.spotify.com/dashboard)
# Add redirect URI: http://127.0.0.1:3000/api/auth/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Base URL of the app (used by Auth.js for callback URLs in production)
# Local dev can omit this; set it when deploying.
# AUTH_URL=https://your-domain.com
